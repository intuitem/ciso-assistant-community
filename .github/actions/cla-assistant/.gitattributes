# The repo root applies `* text=auto eol=lf`, which would rewrite the bundler
# output and change its bytes. Store dist/index.js verbatim so the committed
# file stays byte-identical to the verified, reproducible ncc build
# (sha256 a44111084c0d4782206c04b4276292f7fec6d1f7a33525512fbeef3242079dfb)
# and so the dist-check CI rebuild diffs cleanly.
dist/index.js -text
